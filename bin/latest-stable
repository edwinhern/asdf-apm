#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

latest_url="${GH_API}/releases/latest"
auth_header=""

if [[ -n "${GITHUB_API_TOKEN:-}" ]]; then
  auth_header="Authorization: token ${GITHUB_API_TOKEN}"
fi

if [[ -n "${auth_header}" ]]; then
  tag=$(curl -fsSL -H "${auth_header}" "${latest_url}" | grep -o '"tag_name": *"[^"]*"' | grep -o '"v[^"]*"' | tr -d '"v' || true)
else
  tag=$(curl -fsSL "${latest_url}" | grep -o '"tag_name": *"[^"]*"' | grep -o '"v[^"]*"' | tr -d '"v' || true)
fi

if [[ -z "${tag}" ]]; then
  # Fallback: pick latest from list-all
  tag=$(list_all_versions | tr ' ' '\n' | grep -v '^$' | tail -n1)
fi

echo "${tag}"
